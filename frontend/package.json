{
  "name": "velgarien-platform",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check ../biome.json frontend/src/",
    "lint:fix": "biome check --write ../biome.json frontend/src/",
    "typecheck": "tsc --noEmit",
    "lint:docs": "markdownlint-cli2 '../docs/**/*.md'",
    "docs:index": "node ../scripts/generate-docs-index.mjs"
  },
  "dependencies": {
    "@lit-labs/preact-signals": "^1.0.3",
    "@lit-labs/router": "^0.1.4",
    "@lit/localize": "^0.12.2",
    "@lit/reactive-element": "^2.0.0",
    "@preact/signals-core": "^1.8.0",
    "@supabase/supabase-js": "^2.45.0",
    "3d-force-graph": "^1.79.1",
    "echarts": "^6.0.0",
    "lit": "^3.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@lit/localize-tools": "^0.8.1",
    "@playwright/test": "^1.58.2",
    "@types/three": "^0.183.1",
    "happy-dom": "^20.7.0",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
